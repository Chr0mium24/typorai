{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "outDir": ".server-dist",
    "rootDir": "."
  },
  "include": ["server/**/*.ts", "shared/**/*.ts"]
}
